# ============================================================================
# APEX AI v14 — Environment Variables
# ============================================================================
# 1. Copy this file:    cp .env.example .env
# 2. Set values below   (everything has a sensible dev default if you skip it)
# 3. Restart the server
#
# Everything is optional EXCEPT in production, where you MUST change
# SESSION_SECRET to a random 32+ character string.
# ============================================================================


# ── AUTHENTICATION (cookie-based sessions, no JWT) ──────────────────────────
# A long random string used to sign the session cookie. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=apex-ai-dev-session-secret-please-change-in-production

# Set to true only when serving over HTTPS in production.
# When false (default), the cookie works over plain http for local dev.
COOKIE_SECURE=false

# 'lax' (default) — cookie sent on top-level navigations and same-site requests.
# 'strict' — cookie not sent on cross-site navigations at all.
# 'none'   — cookie sent on every request. REQUIRES COOKIE_SECURE=true.
COOKIE_SAMESITE=lax


# ── LLM PROVIDER ────────────────────────────────────────────────────────────
# The chatbot picks the first provider that has a working key.
# Recommended: Groq (fastest, free tier, Llama 3.1).

LLM_PROVIDER=groq

# Get one at https://console.groq.com/keys (it starts with 'gsk_')
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# Optional: OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: local LLM via Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b


# ── DATABASE ────────────────────────────────────────────────────────────────
# Default is SQLite — zero setup, perfect for dev & demo.
# For prod, switch to Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/apex
DATABASE_URL=sqlite+aiosqlite:///./apex_ai.db


# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. With cookie auth you CANNOT use '*'
# (the browser will refuse to send credentials to a wildcard origin).
# Pin this to your frontend URL.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ── COMPUTER VISION ─────────────────────────────────────────────────────────
# Pose backbone: 'yolo' = Ultralytics YOLOv8-pose (recommended — the AI Gym
# reference architecture). 'mediapipe' = legacy MediaPipe path (fallback).
POSE_BACKEND=yolo

# YOLO checkpoint. A bare model name (auto-downloaded by Ultralytics on first
# run, cached under ~/.config/Ultralytics/) or an absolute path to a .pt file.
# Variants: yolov8n-pose.pt (~6 MB, fastest), yolov8s-pose.pt, yolov8m-pose.pt
# (~26 MB, more accurate), yolov8l-pose.pt, yolov8x-pose.pt.
YOLO_MODEL_PATH=yolov8n-pose.pt

# YOLO detection confidence threshold (lower → more recalls, higher → fewer
# false positives).
YOLO_CONF_THRESHOLD=0.30

# YOLO inference image size. 640 is the standard; 480 is faster on weak CPUs.
YOLO_IMG_SIZE=640

# CV device. 'auto' → CUDA if available, otherwise CPU. Force with 'cuda' or 'cpu'.
CV_DEVICE=auto


# ── EMBEDDINGS / RAG ────────────────────────────────────────────────────────
EMBEDDING_DEVICE=cpu


# ── SERVER ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
